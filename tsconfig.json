{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "jsx": "react-jsx",
        "types": ["vite/client", "vitest/globals"],
        "resolveJsonModule": true,
        "ignoreDeprecations": "6.0"
    },
    "include": ["src"]
}